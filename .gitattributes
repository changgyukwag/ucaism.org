# Normalize text files to LF line endings for GitHub Pages / static site consistency
* text=auto eol=lf

# Web source files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.svg  text eol=lf
*.ico  binary
*.pdf  binary
*.zip  binary
*.docx binary
*.pptx binary
